# =============================================================================
# Copia este archivo a ".env" en la raíz del proyecto y ajusta los valores.
#   cp .env.example .env
#
# NUNCA subas ".env" a GitHub (ya está en .gitignore).
# =============================================================================

# --- API (.NET) ---
ASPNETCORE_ENVIRONMENT=Production

# Obligatorio en producción: mínimo 32 caracteres aleatorios.
JWT_KEY=change-me-generate-a-long-random-secret-at-least-32-chars
JWT_ISSUER=LogisticsApi
JWT_AUDIENCE=LogisticsFrontend

# SQLite dentro del contenedor (volumen Docker en /app/data).
CONNECTION_STRING=Data Source=/app/data/logistics.db

# --- Puertos expuestos en el host ---
API_PORT=5253
FRONTEND_PORT=5173

# --- Frontend (Vite, inyectado en BUILD del contenedor) ---
# URL pública de la API tal como la ve el navegador del usuario.
VITE_API_BASE_URL=http://localhost:5253
